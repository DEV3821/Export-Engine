{
  "schema": "sami.knowledgeStoreRolloutProfile.v1",
  "project": "SAMI Outlook KnowledgeStore Export Engine",
  "repoRoot": "C:\\Tools\\Export engine",
  "defaultMode": "validate_then_live_incremental",
  "mailboxReadDefault": false,
  "allowFullBackfillDefault": false,
  "allowIncrementalReadAfterValidation": true,
  "primaryStoreOnly": true,
  "includeSentItems": true,
  "requireSentItemsForLiveMode": true,
  "excludeDeleted": true,
  "excludeJunk": true,
  "excludeDrafts": true,
  "excludeOutbox": true,
  "excludeSyncIssues": true,
  "excludeCalendar": true,
  "excludeContacts": true,
  "excludeImportedPSTsByDefault": true,
  "requireVaultNoteCountGtZeroIfVaultEnabled": true,
  "requireConversationJoinPass": true,
  "requireNoFixtureData": true,
  "requireNoStorePrefixedPaths": true,
  "requireExplicitAttachmentStatus": true,
  "requireBackupBeforeDerivedRebuild": true,
  "liveRefresh": {
    "enabledByDefaultAfterValidation": true,
    "mode": "polling_incremental_refresh",
    "defaultPollingIntervalMinutes": 5,
    "minimumPollingIntervalMinutes": 1,
    "overlapWindowHours": 72,
    "includeInboxSideFolders": true,
    "includeSentItems": true,
    "readOnlyOutlook": true,
    "mailboxWrite": false,
    "kanbanWrite": false,
    "cloudApiCalls": false
  }
}
